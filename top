frontend/app.ts
const API_URL = "http://localhost:3000";

type ApiResponse = {
  message?: string;
  error?: string;
  datetime?: string;
  login?: string;
  pointages?: {
    type: "arrivee" | "depart";
    datetime: string;
  }[];
};

function getInputValue(id: string): string {
  const input = document.getElementById(id) as HTMLInputElement;
  return input.value.trim();
}

function showMessage(elementId: string, message: string, isError: boolean = false): void {
  const element = document.getElementById(elementId) as HTMLElement;

  element.textContent = message;
  element.className = isError
    ? "message error-message"
    : "message success-message";
}

async function postData(route: string, data: object): Promise<ApiResponse> {
  const response = await fetch(`${API_URL}${route}`, {
    method: "POST",
    headers: {
      "Content-Type": "application/json"
    },
    body: JSON.stringify(data)
  });

  const result = await response.json();

  return result;
}

/**
 * Création de compte
 */
const registerBtn = document.getElementById("registerBtn") as HTMLButtonElement;

registerBtn.addEventListener("click", async () => {
  const login = getInputValue("registerLogin");
  const password = getInputValue("registerPassword");

  if (!login || !password) {
    showMessage("registerMessage", "Veuillez remplir tous les champs.", true);
    return;
  }

  try {
    const result = await postData("/register", {
      login,
      password
    });

    if (result.error) {
      showMessage("registerMessage", result.error, true);
    } else {
      showMessage("registerMessage", result.message || "Compte créé.");
    }
  } catch (error) {
    showMessage("registerMessage", "Erreur de connexion au serveur.", true);
  }
});

/**
 * Arrivée
 */
const arriveeBtn = document.getElementById("arriveeBtn") as HTMLButtonElement;

arriveeBtn.addEventListener("click", async () => {
  const login = getInputValue("pointageLogin");
  const password = getInputValue("pointagePassword");

  if (!login || !password) {
    showMessage("pointageMessage", "Veuillez remplir tous les champs.", true);
    return;
  }

  try {
    const result = await postData("/arrivee", {
      login,
      password
    });

    if (result.error) {
      showMessage("pointageMessage", result.error, true);
    } else {
      showMessage(
        "pointageMessage",
        `${result.message} Heure : ${result.datetime}`
      );
    }
  } catch (error) {
    showMessage("pointageMessage", "Erreur de connexion au serveur.", true);
  }
});

/**
 * Départ
 */
const departBtn = document.getElementById("departBtn") as HTMLButtonElement;

departBtn.addEventListener("click", async () => {
  const login = getInputValue("pointageLogin");
  const password = getInputValue("pointagePassword");

  if (!login || !password) {
    showMessage("pointageMessage", "Veuillez remplir tous les champs.", true);
    return;
  }

  try {
    const result = await postData("/depart", {
      login,
      password
    });

    if (result.error) {
      showMessage("pointageMessage", result.error, true);
    } else {
      showMessage(
        "pointageMessage",
        `${result.message} Heure : ${result.datetime}`
      );
    }
  } catch (error) {
    showMessage("pointageMessage", "Erreur de connexion au serveur.", true);
  }
});

/**
 * Visualisation des horaires
 */
const horairesBtn = document.getElementById("horairesBtn") as HTMLButtonElement;

horairesBtn.addEventListener("click", async () => {
  const login = getInputValue("horairesLogin");
  const password = getInputValue("horairesPassword");
  const horairesResult = document.getElementById("horairesResult") as HTMLElement;

  horairesResult.innerHTML = "";

  if (!login || !password) {
    showMessage("horairesMessage", "Veuillez remplir tous les champs.", true);
    return;
  }

  try {
    const result = await postData("/horaires", {
      login,
      password
    });

    if (result.error) {
      showMessage("horairesMessage", result.error, true);
      return;
    }

    showMessage("horairesMessage", "Horaires récupérés avec succès.");

    if (!result.pointages || result.pointages.length === 0) {
      horairesResult.innerHTML = "<p>Aucun pointage trouvé.</p>";
      return;
    }

    let html = `
      <table>
        <thead>
          <tr>
            <th>Type</th>
            <th>Date et heure</th>
          </tr>
        </thead>
        <tbody>
    `;

    for (const pointage of result.pointages) {
      const typeLabel = pointage.type === "arrivee" ? "Arrivée" : "Départ";

      html += `
        <tr>
          <td>${typeLabel}</td>
          <td>${pointage.datetime}</td>
        </tr>
      `;
    }

    html += `
        </tbody>
      </table>
    `;

    horairesResult.innerHTML = html;
  } catch (error) {
    showMessage("horairesMessage", "Erreur de connexion au serveur.", true);
  }
});

