src/server.ts

import Fastify from "fastify";
import cors from "@fastify/cors";
import bcrypt from "bcryptjs";
import { db, User, Pointage } from "./db";

const app = Fastify({
  logger: true
});

app.register(cors, {
  origin: true
});

type AuthBody = {
  login: string;
  password: string;
};

function getDateTimeString(): string {
  const now = new Date();

  return now.toLocaleString("fr-FR", {
    year: "numeric",
    month: "2-digit",
    day: "2-digit",
    hour: "2-digit",
    minute: "2-digit",
    second: "2-digit"
  });
}

function findUserByLogin(login: string): User | undefined {
  return db
    .prepare("SELECT * FROM users WHERE login = ?")
    .get(login) as User | undefined;
}

function authenticate(login: string, password: string): User | null {
  const user = findUserByLogin(login);

  if (!user) {
    return null;
  }

  const validPassword = bcrypt.compareSync(password, user.password);

  if (!validPassword) {
    return null;
  }

  return user;
}

app.get("/", async () => {
  return {
    message: "API de pointage en ligne opérationnelle"
  };
});

/**
 * Création de compte
 */
app.post("/register", async (request, reply) => {
  const body = request.body as AuthBody;

  if (!body.login || !body.password) {
    return reply.code(400).send({
      error: "Login et mot de passe obligatoires."
    });
  }

  const existingUser = findUserByLogin(body.login);

  if (existingUser) {
    return reply.code(409).send({
      error: "Ce login existe déjà."
    });
  }

  const hashedPassword = bcrypt.hashSync(body.password, 10);

  const insertUser = db.prepare(`
    INSERT INTO users (login, password)
    VALUES (?, ?)
  `);

  insertUser.run(body.login, hashedPassword);

  return reply.code(201).send({
    message: "Compte créé avec succès."
  });
});

/**
 * Saisie d'arrivée
 */
app.post("/arrivee", async (request, reply) => {
  const body = request.body as AuthBody;

  if (!body.login || !body.password) {
    return reply.code(400).send({
      error: "Login et mot de passe obligatoires."
    });
  }

  const user = authenticate(body.login, body.password);

  if (!user) {
    return reply.code(401).send({
      error: "Identifiants incorrects."
    });
  }

  const lastPointage = db
    .prepare(
      `
      SELECT * FROM pointages
      WHERE user_id = ?
      ORDER BY id DESC
      LIMIT 1
    `
    )
    .get(user.id) as Pointage | undefined;

  if (lastPointage && lastPointage.type === "arrivee") {
    return reply.code(400).send({
      error: "Vous avez déjà indiqué une arrivée sans départ."
    });
  }

  const datetime = getDateTimeString();

  db.prepare(
    `
    INSERT INTO pointages (user_id, type, datetime)
    VALUES (?, 'arrivee', ?)
  `
  ).run(user.id, datetime);

  return {
    message: "Arrivée enregistrée avec succès.",
    datetime
  };
});

/**
 * Saisie de départ
 */
app.post("/depart", async (request, reply) => {
  const body = request.body as AuthBody;

  if (!body.login || !body.password) {
    return reply.code(400).send({
      error: "Login et mot de passe obligatoires."
    });
  }

  const user = authenticate(body.login, body.password);

  if (!user) {
    return reply.code(401).send({
      error: "Identifiants incorrects."
    });
  }

  const lastPointage = db
    .prepare(
      `
      SELECT * FROM pointages
      WHERE user_id = ?
      ORDER BY id DESC
      LIMIT 1
    `
    )
    .get(user.id) as Pointage | undefined;

  if (!lastPointage || lastPointage.type !== "arrivee") {
    return reply.code(400).send({
      error: "Impossible d’indiquer un départ sans arrivée préalable."
    });
  }

  const datetime = getDateTimeString();

  db.prepare(
    `
    INSERT INTO pointages (user_id, type, datetime)
    VALUES (?, 'depart', ?)
  `
  ).run(user.id, datetime);

  return {
    message: "Départ enregistré avec succès.",
    datetime
  };
});

/**
 * Visualisation des horaires
 */
app.post("/horaires", async (request, reply) => {
  const body = request.body as AuthBody;

  if (!body.login || !body.password) {
    return reply.code(400).send({
      error: "Login et mot de passe obligatoires."
    });
  }

  const user = authenticate(body.login, body.password);

  if (!user) {
    return reply.code(401).send({
      error: "Identifiants incorrects."
    });
  }

  const pointages = db
    .prepare(
      `
      SELECT type, datetime
      FROM pointages
      WHERE user_id = ?
      ORDER BY id ASC
    `
    )
    .all(user.id);

  return {
    login: user.login,
    pointages
  };
});

const start = async () => {
  try {
    await app.listen({
      port: 3000,
      host: "0.0.0.0"
    });

    console.log("Serveur lancé sur http://localhost:3000");
  } catch (error) {
    app.log.error(error);
    process.exit(1);
  }
};

start();


